# Copy to .env (gitignored) and fill in. scripts/lib/config.sh sources this
# automatically on every run, so once it's set you don't need to export
# anything manually.

# Required for the multi-cluster (MODE=multi) variant — Solo Enterprise for
# Istio license. Get it from your Solo internal channel (employee trial /
# field-engineering Slack). Single-cluster mode does not need this.
SOLO_ISTIO_LICENSE_KEY=

# Pinned Istio version for the multi-cluster install. Matches the tags in
# us-docker.pkg.dev/soloio-img/istio-helm/* and .../istio/*.
SOLO_ISTIO_VERSION=1.29.2-patch0-solo

# Anthropic API key for the kagent agents (same as single-cluster mode).
ANTHROPIC_API_KEY=
