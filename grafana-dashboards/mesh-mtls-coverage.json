{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "title": "TrustUsBank — Mesh & mTLS Coverage",
  "tags": ["trustusbank", "dora", "ambient"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "ztunnel pods Ready (per node)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "kube_daemonset_status_number_ready{daemonset=\"ztunnel\",namespace=\"istio-system\"}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] } } }
    },
    {
      "type": "stat",
      "title": "HBONE connections (last 5m)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum(rate(istio_tcp_connections_opened_total{security_policy=\"mutual_tls\"}[5m]))", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "% requests with mTLS",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "100 * sum(rate(istio_requests_total{security_policy=\"mutual_tls\"}[5m])) / sum(rate(istio_requests_total[5m]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 99 }, { "color": "green", "value": 100 }] } } }
    },
    {
      "type": "timeseries",
      "title": "Cross-namespace traffic (per source ns)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "targets": [
        { "expr": "sum by (source_workload_namespace, destination_workload_namespace) (rate(istio_requests_total[1m]))", "refId": "A", "legendFormat": "{{source_workload_namespace}} → {{destination_workload_namespace}}" }
      ]
    },
    {
      "type": "table",
      "title": "AuthorizationPolicy denies (last 15m)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        { "expr": "sum by (source_principal, destination_workload, response_code) (increase(istio_requests_total{response_code=\"403\"}[15m]))", "refId": "A", "format": "table" }
      ]
    }
  ]
}
